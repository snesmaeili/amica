{
    "schema_version": "v1",
    "dataset": {
        "source": "mne.datasets.sample",
        "subject": "sample",
        "modality": "eeg",
        "reference": "average"
    },
    "forward": {
        "filename": "sample_audvis-meg-eeg-oct-6-fwd.fif",
        "orientation": "fixed",
        "pick": "eeg"
    },
    "sources": {
        "n_true": 32,
        "parcellation": "aparc",
        "label_random_state": 0,
        "exclude_label_prefixes": ["unknown"],
        "waveform": {
            "kind": "laplacian",
            "bandpass_hz": [1.0, 40.0],
            "amplitude_nAm": 50.0
        }
    },
    "recording": {
        "sfreq_sim_hz": 600.0,
        "sfreq_final_hz": 250.0,
        "duration_s": 1200.0
    },
    "preprocess": {
        "highpass_hz": 1.0,
        "reference": "average",
        "pca_n_components": 32
    },
    "conditions": [
        {
            "id": "clean",
            "add_noise": false,
            "iir_filter": null,
            "noise_scale": 0.0,
            "add_eog": false,
            "add_ecg": false
        },
        {
            "id": "noise",
            "add_noise": true,
            "iir_filter": [0.2, -0.2, 0.04],
            "noise_scale": 1.0,
            "add_eog": false,
            "add_ecg": false
        },
        {
            "id": "noise_eog",
            "add_noise": true,
            "iir_filter": [0.2, -0.2, 0.04],
            "noise_scale": 1.0,
            "add_eog": true,
            "add_ecg": false
        },
        {
            "id": "noise_ecg",
            "add_noise": true,
            "iir_filter": [0.2, -0.2, 0.04],
            "noise_scale": 1.0,
            "add_eog": false,
            "add_ecg": true
        },
        {
            "id": "full",
            "add_noise": true,
            "iir_filter": [0.2, -0.2, 0.04],
            "noise_scale": 1.0,
            "add_eog": true,
            "add_ecg": true
        }
    ],
    "seeds": [101, 202, 303, 404, 505, 606, 707, 808, 909, 1010],
    "methods": {
        "jax_gpu": {"family": "amica", "backend": "jax", "device": "gpu", "max_iter": 3000},
        "jax_cpu": {"family": "amica", "backend": "jax", "device": "cpu", "max_iter": 3000},
        "numpy_cpu": {"family": "amica", "backend": "numpy", "device": "cpu", "max_iter": 3000},
        "picard": {"family": "comparator", "method": "picard", "max_iter": 5000, "tol": 1.0e-6, "ortho": false, "extended": true},
        "infomax": {"family": "comparator", "method": "infomax", "max_iter": 5000, "w_change": 1.0e-7, "extended": true},
        "fastica": {"family": "comparator", "method": "fastica", "max_iter": 5000, "tol": 1.0e-6, "fun": "logcosh"}
    },
    "_notes": {
        "task_index_map": "Slurm array index 1..50 maps as: condition_idx = (idx-1)//10, seed_idx = (idx-1)%10. Condition order matches the 'conditions' list above.",
        "honesty": "MNE provides no built-in EMG/muscle simulator. This benchmark covers noise + EOG + ECG only; the paper makes that limit explicit."
    }
}
