{
    "schema_version": "v1-mixed-amica10k",
    "_purpose": "Identical to benchmark_v1_mixed.json EXCEPT AMICA backends use max_iter=10000 (vs 3000). Tests the hypothesis that AMICA's underperformance on the v1_mixed benchmark is caused by hitting the 3000-iter cap rather than by model/data mismatch. Comparator settings unchanged (we keep the existing fastica/infomax/picard results from the original v1_mixed run and re-fit only the AMICA backends here).",
    "dataset": {
        "source": "mne.datasets.sample",
        "subject": "sample",
        "modality": "eeg",
        "reference": "average"
    },
    "forward": {
        "filename": "sample_audvis-meg-eeg-oct-6-fwd.fif",
        "orientation": "fixed",
        "pick": "eeg"
    },
    "sources": {
        "n_true": 32,
        "parcellation": "aparc",
        "label_random_state": 0,
        "exclude_label_prefixes": ["unknown"],
        "waveform": {
            "kind": "mixture",
            "bandpass_hz": [1.0, 40.0],
            "amplitude_nAm": 50.0,
            "mixture_kinds": [
                {"kind": "laplacian",          "params": {}},
                {"kind": "student_t",          "params": {"df": 3.0}},
                {"kind": "uniform",            "params": {}},
                {"kind": "exponential_signed", "params": {}},
                {"kind": "sinusoid",           "params": {"freq_hz": 10.0, "noise_amp": 0.1}},
                {"kind": "ar1",                "params": {"alpha": 0.95}}
            ]
        }
    },
    "recording": {
        "sfreq_sim_hz": 600.0,
        "sfreq_final_hz": 250.0,
        "duration_s": 1200.0
    },
    "preprocess": {
        "highpass_hz": 1.0,
        "reference": "average",
        "pca_n_components": 32
    },
    "conditions": [
        {"id": "clean",     "add_noise": false, "iir_filter": null,                 "noise_scale": 0.0, "add_eog": false, "add_ecg": false},
        {"id": "noise",     "add_noise": true,  "iir_filter": [0.2, -0.2, 0.04],    "noise_scale": 1.0, "add_eog": false, "add_ecg": false},
        {"id": "noise_eog", "add_noise": true,  "iir_filter": [0.2, -0.2, 0.04],    "noise_scale": 1.0, "add_eog": true,  "add_ecg": false},
        {"id": "noise_ecg", "add_noise": true,  "iir_filter": [0.2, -0.2, 0.04],    "noise_scale": 1.0, "add_eog": false, "add_ecg": true },
        {"id": "full",      "add_noise": true,  "iir_filter": [0.2, -0.2, 0.04],    "noise_scale": 1.0, "add_eog": true,  "add_ecg": true }
    ],
    "seeds": [101, 202, 303, 404, 505, 606, 707, 808, 909, 1010],
    "methods": {
        "jax_gpu":   {"family": "amica",      "backend": "jax",   "device": "gpu", "max_iter": 10000},
        "jax_cpu":   {"family": "amica",      "backend": "jax",   "device": "cpu", "max_iter": 10000},
        "numpy_cpu": {"family": "amica",      "backend": "numpy", "device": "cpu", "max_iter": 10000},
        "picard":    {"family": "comparator", "method": "picard",  "max_iter": 5000, "tol": 1.0e-6, "ortho": false, "extended": true},
        "infomax":   {"family": "comparator", "method": "infomax", "max_iter": 5000, "w_change": 1.0e-7, "extended": true},
        "fastica":   {"family": "comparator", "method": "fastica", "max_iter": 5000, "tol": 1.0e-6, "fun": "logcosh"}
    }
}
