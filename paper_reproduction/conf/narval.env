# Narval HPC environment setup
# Source this file in Slurm scripts: source conf/narval.env

module load python/3.11
module load cuda/12.6

# Activate virtual environment
source /home/sesma/envs/amica/bin/activate

# Threading
export OMP_NUM_THREADS=${SLURM_CPUS_PER_TASK:-4}
export MKL_NUM_THREADS=${SLURM_CPUS_PER_TASK:-4}

# Dataset paths
export DS_PATH="${DS_PATH:-/home/sesma/scratch/ds004505}"

# JAX configuration
export JAX_PLATFORMS="${JAX_PLATFORMS:-cpu}"

# Allocation accounts
export SLURM_ACCOUNT_CPU="${SLURM_ACCOUNT_CPU:-def-kjerbi}"
export SLURM_ACCOUNT_GPU="${SLURM_ACCOUNT_GPU:-def-kjerbi_gpu}"
